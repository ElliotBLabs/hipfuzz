        transparent_crc(p_3152->g_402[i].f0, "p_3152->g_402[i].f0", print_hash_value);

    }
    transparent_crc(p_3152->g_779, "p_3152->g_779", print_hash_value);
    transparent_crc(p_3152->g_1208, "p_3152->g_1208", print_hash_value);
    transparent_crc(p_3152->g_1292, "p_3152->g_1292", print_hash_value);
    transparent_crc(p_3152->g_1321, "p_3152->g_1321", print_hash_value);
    transparent_crc(p_3152->g_1382, "p_3152->g_1382", print_hash_value);
    transparent_crc(p_3152->g_1403, "p_3152->g_1403", print_hash_value);
    for (int i = 0; i < 5; i++)
    {
        for (int j = 0; j < 8; j++)
        {
            transparent_crc(p_3152->g_1483[i][j], "p_3152->g_1483[i][j]", print_hash_value);

        }
    }
    transparent_crc(p_3152->g_1548, "p_3152->g_1548", print_hash_value);
    transparent_crc(p_3152->g_1599, "p_3152->g_1599", print_hash_value);
    transparent_crc(p_3152->g_1702, "p_3152->g_1702", print_hash_value);
    transparent_crc(p_3152->g_1748.f0, "p_3152->g_1748.f0", print_hash_value);
    transparent_crc(p_3152->g_1801, "p_3152->g_1801", print_hash_value);
    transparent_crc(p_3152->g_1832, "p_3152->g_1832", print_hash_value);
    transparent_crc(p_3152->g_1846, "p_3152->g_1846", print_hash_value);
    transparent_crc(p_3152->g_2127, "p_3152->g_2127", print_hash_value);
    transparent_crc(p_3152->g_2183, "p_3152->g_2183", print_hash_value);
    transparent_crc(p_3152->g_2270, "p_3152->g_2270", print_hash_value);
    transparent_crc(p_3152->g_2313, "p_3152->g_2313", print_hash_value);
    transparent_crc(p_3152->g_2681, "p_3152->g_2681", print_hash_value);
    for (int i = 0; i < 2; i++)
    {
        transparent_crc(p_3152->g_2709[i], "p_3152->g_2709[i]", print_hash_value);

    }
    transparent_crc(p_3152->g_3085, "p_3152->g_3085", print_hash_value);
    transparent_crc(p_3152->g_3086, "p_3152->g_3086", print_hash_value);

    // Store result
    int tid = threadIdx.x + blockIdx.x * blockDim.x;
    results[tid] = (crc64_context ^ 0xFFFFFFFFFFFFFFFFUL);
}

// ------------------------------------------------------------------
// Host Main
// ------------------------------------------------------------------
int main(int argc, const char* argv[]) {
    // Config
    const unsigned int num_threads = 4;
    const unsigned int block_size = 4;

    // Host Alloc
    std::vector<uint64_t> h_results(num_threads);
    const size_t results_bytes = sizeof(uint64_t) * h_results.size();

    // Device Alloc
    uint64_t *d_results;
    HIP_CHECK(hipMalloc((void**)&d_results, results_bytes));
    HIP_CHECK(hipMemset(d_results, 0, results_bytes));

    // Dimensions
    const dim3 block_dim(block_size);
    const dim3 grid_dim((num_threads + block_size - 1) / block_size);

    // Launch
    hipLaunchKernelGGL(hipsmith_kernel, grid_dim, block_dim, 0, 0, d_results);
    HIP_CHECK(hipGetLastError());
    HIP_CHECK(hipDeviceSynchronize());

    // Copy Back
    HIP_CHECK(hipMemcpy(h_results.data(), d_results, results_bytes, hipMemcpyDeviceToHost));

    // Free
    HIP_CHECK(hipFree(d_results));

    // Output
    for (size_t i = 0; i < h_results.size(); ++i) {
        printf("Thread %zu CRC: %lu\n", i, h_results[i]);
    }
    return 0;
}
