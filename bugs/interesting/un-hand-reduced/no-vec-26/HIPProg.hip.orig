                transparent_crc(p_1645->g_334[i][j][k], "p_1645->g_334[i][j][k]", print_hash_value);

            }
        }
    }
    transparent_crc(p_1645->g_336, "p_1645->g_336", print_hash_value);
    transparent_crc(p_1645->g_568, "p_1645->g_568", print_hash_value);
    transparent_crc(p_1645->g_589, "p_1645->g_589", print_hash_value);
    transparent_crc(p_1645->g_592, "p_1645->g_592", print_hash_value);
    transparent_crc(p_1645->g_595, "p_1645->g_595", print_hash_value);
    for (int i = 0; i < 2; i++)
    {
        for (int j = 0; j < 10; j++)
        {
            transparent_crc(p_1645->g_597[i][j], "p_1645->g_597[i][j]", print_hash_value);

        }
    }
    transparent_crc(p_1645->g_640, "p_1645->g_640", print_hash_value);
    transparent_crc(p_1645->g_642, "p_1645->g_642", print_hash_value);
    transparent_crc(p_1645->g_685, "p_1645->g_685", print_hash_value);
    transparent_crc(p_1645->g_729, "p_1645->g_729", print_hash_value);
    for (int i = 0; i < 3; i++)
    {
        for (int j = 0; j < 4; j++)
        {
            transparent_crc(p_1645->g_754[i][j], "p_1645->g_754[i][j]", print_hash_value);

        }
    }
    transparent_crc(p_1645->g_807, "p_1645->g_807", print_hash_value);
    transparent_crc(p_1645->g_808, "p_1645->g_808", print_hash_value);
    transparent_crc(p_1645->g_809, "p_1645->g_809", print_hash_value);
    transparent_crc(p_1645->g_810, "p_1645->g_810", print_hash_value);
    transparent_crc(p_1645->g_841, "p_1645->g_841", print_hash_value);
    transparent_crc(p_1645->g_873, "p_1645->g_873", print_hash_value);
    transparent_crc(p_1645->g_874, "p_1645->g_874", print_hash_value);
    transparent_crc(p_1645->g_875, "p_1645->g_875", print_hash_value);
    transparent_crc(p_1645->g_880, "p_1645->g_880", print_hash_value);
    transparent_crc(p_1645->g_881, "p_1645->g_881", print_hash_value);
    transparent_crc(p_1645->g_954, "p_1645->g_954", print_hash_value);
    transparent_crc(p_1645->g_1154, "p_1645->g_1154", print_hash_value);
    transparent_crc(p_1645->g_1155, "p_1645->g_1155", print_hash_value);
    transparent_crc(p_1645->g_1412, "p_1645->g_1412", print_hash_value);
    transparent_crc(p_1645->g_1617, "p_1645->g_1617", print_hash_value);
    transparent_crc(p_1645->g_1625, "p_1645->g_1625", print_hash_value);
    transparent_crc(p_1645->g_1626, "p_1645->g_1626", print_hash_value);

    // Store result
    int tid = threadIdx.x + blockIdx.x * blockDim.x;
    results[tid] = (crc64_context ^ 0xFFFFFFFFFFFFFFFFUL);
}

// ------------------------------------------------------------------
// Host Main
// ------------------------------------------------------------------
int main(int argc, const char* argv[]) {
    // Config
    const unsigned int num_threads = 4;
    const unsigned int block_size = 4;

    // Host Alloc
    std::vector<uint64_t> h_results(num_threads);
    const size_t results_bytes = sizeof(uint64_t) * h_results.size();

    // Device Alloc
    uint64_t *d_results;
    HIP_CHECK(hipMalloc((void**)&d_results, results_bytes));
    HIP_CHECK(hipMemset(d_results, 0, results_bytes));

    // Dimensions
    const dim3 block_dim(block_size);
    const dim3 grid_dim((num_threads + block_size - 1) / block_size);

    // Launch
    hipLaunchKernelGGL(hipsmith_kernel, grid_dim, block_dim, 0, 0, d_results);
    HIP_CHECK(hipGetLastError());
    HIP_CHECK(hipDeviceSynchronize());

    // Copy Back
    HIP_CHECK(hipMemcpy(h_results.data(), d_results, results_bytes, hipMemcpyDeviceToHost));

    // Free
    HIP_CHECK(hipFree(d_results));

    // Output
    for (size_t i = 0; i < h_results.size(); ++i) {
        printf("Thread %zu CRC: %lu\n", i, h_results[i]);
    }
    return 0;
}
