        &p_2389->g_19, // p_2389->g_2384
    };
    c_2390 = c_2391;

    // Execute core logic
    func_1(p_2389);

    // CRC Context
    uint64_t crc64_context = 0xFFFFFFFFFFFFFFFFUL;
    int print_hash_value = 0;
    // Hash variables
    for (int i = 0; i < 10; i++)
