        }
    }
    for (int i = 0; i < 8; i++)
    {
        transparent_crc(p_1867->g_841[i], "p_1867->g_841[i]", print_hash_value);

    }
    transparent_crc(p_1867->g_852, "p_1867->g_852", print_hash_value);
    for (int i = 0; i < 6; i++)
    {
        transparent_crc(p_1867->g_870[i], "p_1867->g_870[i]", print_hash_value);

    }
    transparent_crc(p_1867->g_1076, "p_1867->g_1076", print_hash_value);
    transparent_crc(p_1867->g_1147.f0, "p_1867->g_1147.f0", print_hash_value);
    transparent_crc(p_1867->g_1147.f1, "p_1867->g_1147.f1", print_hash_value);
    transparent_crc(p_1867->g_1147.f2, "p_1867->g_1147.f2", print_hash_value);
