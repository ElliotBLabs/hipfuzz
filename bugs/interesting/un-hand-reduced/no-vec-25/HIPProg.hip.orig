    transparent_crc(p_1867->g_573, "p_1867->g_573", print_hash_value);
    transparent_crc(p_1867->g_686, "p_1867->g_686", print_hash_value);
    transparent_crc(p_1867->g_700, "p_1867->g_700", print_hash_value);
    for (int i = 0; i < 6; i++)
    {
        for (int j = 0; j < 9; j++)
        {
            for (int k = 0; k < 4; k++)
            {
                transparent_crc(p_1867->g_822[i][j][k], "p_1867->g_822[i][j][k]", print_hash_value);

