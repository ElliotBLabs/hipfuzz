    transparent_crc(p_2352->g_789.f0, "p_2352->g_789.f0", print_hash_value);
    transparent_crc(p_2352->g_789.f1, "p_2352->g_789.f1", print_hash_value);
    transparent_crc(p_2352->g_789.f2, "p_2352->g_789.f2", print_hash_value);
    transparent_crc(p_2352->g_807, "p_2352->g_807", print_hash_value);
    transparent_crc(p_2352->g_839, "p_2352->g_839", print_hash_value);
    transparent_crc(p_2352->g_950, "p_2352->g_950", print_hash_value);
    transparent_crc(p_2352->g_1203.f0, "p_2352->g_1203.f0", print_hash_value);
    transparent_crc(p_2352->g_1203.f1, "p_2352->g_1203.f1", print_hash_value);
    transparent_crc(p_2352->g_1203.f2, "p_2352->g_1203.f2", print_hash_value);
    transparent_crc(p_2352->g_1352, "p_2352->g_1352", print_hash_value);
    for (int i = 0; i < 2; i++)
    {
        for (int j = 0; j < 9; j++)
        {
            transparent_crc(p_2352->g_1532[i][j].f0, "p_2352->g_1532[i][j].f0", print_hash_value);

        }
    }
    for (int i = 0; i < 10; i++)
    {
        transparent_crc(p_2352->g_1607[i], "p_2352->g_1607[i]", print_hash_value);

    }
    for (int i = 0; i < 5; i++)
    {
        transparent_crc(p_2352->g_1695[i], "p_2352->g_1695[i]", print_hash_value);

    }
    transparent_crc(p_2352->g_1765, "p_2352->g_1765", print_hash_value);
    for (int i = 0; i < 9; i++)
    {
        transparent_crc(p_2352->g_1766[i], "p_2352->g_1766[i]", print_hash_value);

    }
    for (int i = 0; i < 3; i++)
    {
        for (int j = 0; j < 2; j++)
        {
            for (int k = 0; k < 10; k++)
            {
                transparent_crc(p_2352->g_2005[i][j][k], "p_2352->g_2005[i][j][k]", print_hash_value);

            }
        }
    }
    transparent_crc(p_2352->g_2071, "p_2352->g_2071", print_hash_value);
    transparent_crc(p_2352->g_2074, "p_2352->g_2074", print_hash_value);
    transparent_crc(p_2352->g_2108, "p_2352->g_2108", print_hash_value);
    transparent_crc(p_2352->g_2235, "p_2352->g_2235", print_hash_value);
    transparent_crc(p_2352->g_2238, "p_2352->g_2238", print_hash_value);
    transparent_crc(p_2352->g_2259, "p_2352->g_2259", print_hash_value);
    transparent_crc(p_2352->g_2289.f0, "p_2352->g_2289.f0", print_hash_value);
    transparent_crc(p_2352->g_2289.f1, "p_2352->g_2289.f1", print_hash_value);
    transparent_crc(p_2352->g_2289.f2, "p_2352->g_2289.f2", print_hash_value);

    // Store result
    int tid = threadIdx.x + blockIdx.x * blockDim.x;
    results[tid] = (crc64_context ^ 0xFFFFFFFFFFFFFFFFUL);
}

// ------------------------------------------------------------------
// Host Main
// ------------------------------------------------------------------
int main(int argc, const char* argv[]) {
    // Config
    const unsigned int num_threads = 4;
    const unsigned int block_size = 4;

    // Host Alloc
    std::vector<uint64_t> h_results(num_threads);
    const size_t results_bytes = sizeof(uint64_t) * h_results.size();

    // Device Alloc
    uint64_t *d_results;
    HIP_CHECK(hipMalloc((void**)&d_results, results_bytes));
    HIP_CHECK(hipMemset(d_results, 0, results_bytes));

    // Dimensions
    const dim3 block_dim(block_size);
    const dim3 grid_dim((num_threads + block_size - 1) / block_size);

    // Launch
    hipLaunchKernelGGL(hipsmith_kernel, grid_dim, block_dim, 0, 0, d_results);
    HIP_CHECK(hipGetLastError());
    HIP_CHECK(hipDeviceSynchronize());

    // Copy Back
    HIP_CHECK(hipMemcpy(h_results.data(), d_results, results_bytes, hipMemcpyDeviceToHost));

    // Free
    HIP_CHECK(hipFree(d_results));

    // Output
    for (size_t i = 0; i < h_results.size(); ++i) {
        printf("Thread %zu CRC: %lu\n", i, h_results[i]);
    }
    return 0;
}
