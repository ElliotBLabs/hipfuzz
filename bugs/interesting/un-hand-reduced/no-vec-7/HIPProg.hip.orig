        nullptr, // p_2124->g_1864
        3UL, // p_2124->g_2008
        nullptr, // p_2124->g_2078
        0L, // p_2124->g_2081
        0x51ADL, // p_2124->g_2117
    };
    c_2125 = c_2126;

    // Execute core logic
    func_1(p_2124);

    // CRC Context
    uint64_t crc64_context = 0xFFFFFFFFFFFFFFFFUL;
    int print_hash_value = 0;
    // Hash variables
    transparent_crc(p_2124->g_5, "p_2124->g_5", print_hash_value);
    for (int i = 0; i < 3; i++)
    {
        transparent_crc(p_2124->g_21[i], "p_2124->g_21[i]", print_hash_value);

    }
    for (int i = 0; i < 2; i++)
    {
        transparent_crc(p_2124->g_29[i], "p_2124->g_29[i]", print_hash_value);

    }
    transparent_crc(p_2124->g_33, "p_2124->g_33", print_hash_value);
    transparent_crc(p_2124->g_35, "p_2124->g_35", print_hash_value);
    transparent_crc(p_2124->g_61.f0, "p_2124->g_61.f0", print_hash_value);
    transparent_crc(p_2124->g_73, "p_2124->g_73", print_hash_value);
    transparent_crc(p_2124->g_83, "p_2124->g_83", print_hash_value);
    for (int i = 0; i < 6; i++)
    {
        transparent_crc(p_2124->g_86[i].f0, "p_2124->g_86[i].f0", print_hash_value);
        transparent_crc(p_2124->g_86[i].f1, "p_2124->g_86[i].f1", print_hash_value);
        transparent_crc(p_2124->g_86[i].f2, "p_2124->g_86[i].f2", print_hash_value);

    }
    transparent_crc(p_2124->g_87.f0, "p_2124->g_87.f0", print_hash_value);
    transparent_crc(p_2124->g_105, "p_2124->g_105", print_hash_value);
    transparent_crc(p_2124->g_108, "p_2124->g_108", print_hash_value);
    transparent_crc(p_2124->g_110, "p_2124->g_110", print_hash_value);
    transparent_crc(p_2124->g_188, "p_2124->g_188", print_hash_value);
    for (int i = 0; i < 4; i++)
    {
        transparent_crc(p_2124->g_205[i], "p_2124->g_205[i]", print_hash_value);

    }
    transparent_crc(p_2124->g_216, "p_2124->g_216", print_hash_value);
    for (int i = 0; i < 1; i++)
    {
        for (int j = 0; j < 10; j++)
        {
            for (int k = 0; k < 2; k++)
            {
                transparent_crc(p_2124->g_235[i][j][k].f0, "p_2124->g_235[i][j][k].f0", print_hash_value);

            }
        }
    }
    transparent_crc(p_2124->g_322, "p_2124->g_322", print_hash_value);
    for (int i = 0; i < 7; i++)
    {
        for (int j = 0; j < 2; j++)
        {
            for (int k = 0; k < 3; k++)
            {
                transparent_crc(p_2124->g_337[i][j][k], "p_2124->g_337[i][j][k]", print_hash_value);

            }
        }
    }
    transparent_crc(p_2124->g_404.f0, "p_2124->g_404.f0", print_hash_value);
    transparent_crc(p_2124->g_404.f1, "p_2124->g_404.f1", print_hash_value);
    transparent_crc(p_2124->g_404.f2, "p_2124->g_404.f2", print_hash_value);
    transparent_crc(p_2124->g_404.f3, "p_2124->g_404.f3", print_hash_value);
    transparent_crc(p_2124->g_535, "p_2124->g_535", print_hash_value);
    transparent_crc(p_2124->g_652, "p_2124->g_652", print_hash_value);
    transparent_crc(p_2124->g_662, "p_2124->g_662", print_hash_value);
    transparent_crc(p_2124->g_672.f0, "p_2124->g_672.f0", print_hash_value);
    transparent_crc(p_2124->g_672.f1, "p_2124->g_672.f1", print_hash_value);
    transparent_crc(p_2124->g_672.f2, "p_2124->g_672.f2", print_hash_value);
    for (int i = 0; i < 2; i++)
    {
        for (int j = 0; j < 1; j++)
        {
            for (int k = 0; k < 8; k++)
            {
                transparent_crc(p_2124->g_835[i][j][k], "p_2124->g_835[i][j][k]", print_hash_value);

            }
        }
    }
    transparent_crc(p_2124->g_860, "p_2124->g_860", print_hash_value);
    transparent_crc(p_2124->g_928, "p_2124->g_928", print_hash_value);
    transparent_crc(p_2124->g_938, "p_2124->g_938", print_hash_value);
    for (int i = 0; i < 10; i++)
    {
        for (int j = 0; j < 8; j++)
        {
            for (int k = 0; k < 3; k++)
            {
                transparent_crc(p_2124->g_978[i][j][k], "p_2124->g_978[i][j][k]", print_hash_value);

            }
        }
    }
    transparent_crc(p_2124->g_1028, "p_2124->g_1028", print_hash_value);
    transparent_crc(p_2124->g_1076, "p_2124->g_1076", print_hash_value);
    transparent_crc(p_2124->g_1270, "p_2124->g_1270", print_hash_value);
    transparent_crc(p_2124->g_1400, "p_2124->g_1400", print_hash_value);
    transparent_crc(p_2124->g_1557, "p_2124->g_1557", print_hash_value);
    transparent_crc(p_2124->g_2008, "p_2124->g_2008", print_hash_value);
    transparent_crc(p_2124->g_2081, "p_2124->g_2081", print_hash_value);
    transparent_crc(p_2124->g_2117, "p_2124->g_2117", print_hash_value);

    // Store result
    int tid = threadIdx.x + blockIdx.x * blockDim.x;
    results[tid] = (crc64_context ^ 0xFFFFFFFFFFFFFFFFUL);
}

// ------------------------------------------------------------------
// Host Main
// ------------------------------------------------------------------
int main(int argc, const char* argv[]) {
    // Config
    const unsigned int num_threads = 4;
    const unsigned int block_size = 4;

    // Host Alloc
    std::vector<uint64_t> h_results(num_threads);
    const size_t results_bytes = sizeof(uint64_t) * h_results.size();

    // Device Alloc
    uint64_t *d_results;
    HIP_CHECK(hipMalloc((void**)&d_results, results_bytes));
    HIP_CHECK(hipMemset(d_results, 0, results_bytes));

    // Dimensions
    const dim3 block_dim(block_size);
    const dim3 grid_dim((num_threads + block_size - 1) / block_size);

    // Launch
    hipLaunchKernelGGL(hipsmith_kernel, grid_dim, block_dim, 0, 0, d_results);
    HIP_CHECK(hipGetLastError());
    HIP_CHECK(hipDeviceSynchronize());

    // Copy Back
    HIP_CHECK(hipMemcpy(h_results.data(), d_results, results_bytes, hipMemcpyDeviceToHost));

    // Free
    HIP_CHECK(hipFree(d_results));

    // Output
    for (size_t i = 0; i < h_results.size(); ++i) {
        printf("Thread %zu CRC: %lu\n", i, h_results[i]);
    }
    return 0;
}
