    transparent_crc(p_2202->g_341.f0, "p_2202->g_341.f0", print_hash_value);
    for (int i = 0; i < 9; i++)
    {
        for (int j = 0; j < 3; j++)
        {
            for (int k = 0; k < 9; k++)
            {
                transparent_crc(p_2202->g_363[i][j][k].f0, "p_2202->g_363[i][j][k].f0", print_hash_value);
                transparent_crc(p_2202->g_363[i][j][k].f1, "p_2202->g_363[i][j][k].f1", print_hash_value);
                transparent_crc(p_2202->g_363[i][j][k].f2, "p_2202->g_363[i][j][k].f2", print_hash_value);
                transparent_crc(p_2202->g_363[i][j][k].f3, "p_2202->g_363[i][j][k].f3", print_hash_value);
                transparent_crc(p_2202->g_363[i][j][k].f4, "p_2202->g_363[i][j][k].f4", print_hash_value);

            }
        }
    }
    transparent_crc(p_2202->g_380, "p_2202->g_380", print_hash_value);
    transparent_crc(p_2202->g_763, "p_2202->g_763", print_hash_value);
    transparent_crc(p_2202->g_823.f0, "p_2202->g_823.f0", print_hash_value);
